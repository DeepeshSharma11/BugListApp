# Supabase server credentials (use service role key on server only)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optionally the anon key if needed (do NOT use service role in client)
SUPABASE_ANON_KEY=your-anon-key
# FastAPI server
PORT=8000
# Optional admin secret to protect admin endpoints (set to a strong value)
ADMIN_SECRET=supersecretvalue
